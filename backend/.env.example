# ============================================
# SYNAPSE Backend — Environment Configuration
# ============================================

# --- Application ---
APP_NAME=SYNAPSE
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./synapse.db

# --- AI Module ---
GNN_MODEL_PATH=./models/deic_gnn.pt
ANOMALY_THRESHOLD=0.6
MAML_INNER_LR=0.01
MAML_OUTER_LR=0.001
MAML_INNER_STEPS=3
EWC_LAMBDA=5000

# --- LLM ---
LLM_PROVIDER=mock
# LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
